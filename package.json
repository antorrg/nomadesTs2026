{
  "name": "nomadeswebsite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "dev": "cross-env NODE_ENV=development concurrently \"vite\" \"tsx watch --tsconfig tsconfig.server.json server.ts\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "lint": "eslint . --fix",
    "preview": "cross-env NODE_ENV=development concurrently \"vite preview\" \"tsx watch --tsconfig tsconfig.server.json server.ts\"",
    "unit:test": "cross-env NODE_ENV=test vitest --run",
    "test": "cross-env NODE_ENV=test vitest --run E2E.spec.ts"
  },
  "author": "antorrg",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/react-slick": "^0.23.13",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cloudinary": "^2.9.0",
    "connect-session-sequelize": "^7.1.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "csurf": "^1.11.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.17.2",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.0",
    "react-slick": "^0.31.0",
    "react-toastify": "^11.0.5",
    "req-valid-express": "^1.0.8",
    "resolvers": "^1.0.0",
    "sequelize": "^6.37.7",
    "slick-carousel": "^1.8.1",
    "sweetalert2": "^11.26.18",
    "sweetalert2-react-content": "^5.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sass": "^1.97.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
